# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-key

# --- Neo4j AuraDB (knowledge graph) ---
# From the AuraDB console when you create a free instance. The URI uses +s (TLS).
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-password

# --- Qdrant (local Docker) ---
QDRANT_URL=http://localhost:6333

# --- Neon Postgres (structured data) ---
# From the Neon dashboard -> Connection string (psql). Add the +psycopg2 driver
# and keep sslmode=require (the app enforces it, but include it to be explicit).
DATABASE_URL=postgresql+psycopg2://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# --- Optional overrides (safe defaults exist in config.py) ---
# FRONTEND_ORIGIN=http://localhost:3000
# QDRANT_COLLECTION=sanjeevani_chunks
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536
# LLM_MODEL=gpt-4o-mini
